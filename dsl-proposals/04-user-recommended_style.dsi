model = recommended_style
kind = ode

params = ka, cl, v, tlag, f_oral
covariates = wt@linear
states = depot, central
outputs = cp

bolus(oral) -> depot
infusion(iv) -> central

lag(oral) = tlag
fa(oral) = f_oral

cl_i = if (wt > 0.0) cl * pow(wt / 70.0, 0.75) else cl
v_i = v
ke = cl_i / v_i

dx(depot) = -ka * depot
dx(central) = ka * depot - ke * central

out(cp) = central / v_i ~ continuous()