{
  "schema": "2.0",
  "id": "pk/2cmt-iv-ode",
  "type": "ode",
  "parameters": ["CL", "V1", "Q", "V2"],
  "compartments": ["central", "peripheral"],
  "diffeq": {
    "central": "-CL/V1 * central - Q/V1 * central + Q/V2 * peripheral + rateiv[0]",
    "peripheral": "Q/V1 * central - Q/V2 * peripheral"
  },
  "outputs": [{ "id": "cp", "equation": "central / V1" }],
  "editor": {
    "display": {
      "name": "Two-Compartment IV Bolus (ODE)",
      "category": "pk",
      "tags": ["2-compartment", "iv", "ode", "clearance"]
    },
    "documentation": {
      "summary": "Two-compartment ODE model using clearance and inter-compartmental clearance parameterization"
    }
  }
}
