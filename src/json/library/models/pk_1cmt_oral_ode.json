{
  "schema": "2.0",
  "id": "pk/1cmt-oral-ode",
  "type": "ode",
  "parameters": ["ka", "CL", "V"],
  "compartments": ["depot", "central"],
  "diffeq": {
    "depot": "-ka * depot",
    "central": "ka * depot - CL/V * central"
  },
  "outputs": [{ "id": "cp", "equation": "central / V" }],
  "editor": {
    "display": {
      "name": "One-Compartment Oral (ODE)",
      "category": "pk",
      "tags": [
        "1-compartment",
        "oral",
        "ode",
        "clearance",
        "first-order-absorption"
      ]
    },
    "documentation": {
      "summary": "One-compartment ODE model for oral dosing with clearance (CL) and volume (V) parameterization"
    }
  }
}
